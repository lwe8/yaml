{
  "name": "@suseejs/yaml",
  "version": "0.1.0",
  "description": "Yaml frontmatter from markdown and load yaml config files",
  "type": "module",
  "main": "dist/index.cjs",
  "types": "dist/index.d.cts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "susee"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lwe8/yaml.git"
  },
  "keywords": [],
  "author": {
    "name": "Pho Thin Mg",
    "email": "phothinmg@disroot.org",
    "url": "https://phothinmg.github.io/"
  },
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/lwe8/yaml/issues"
  },
  "homepage": "https://github.com/lwe8/yaml#readme",
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.8.0",
    "susee": "^1.5.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  },
  "files": [
    "package.json",
    "README.md",
    "LICENSE",
    "dist/**/*"
  ]
